# Copy this file to .env.local or set these values in your server environment.
# Never commit real service account JSON keys.

# Absolute path to your downloaded Google service account key JSON.
GOOGLE_APPLICATION_CREDENTIALS=E:\26사업계획서1\secrets\service-account.json

# Your personal Google account. The agent will share created sheets with this email.
GOOGLE_SHARE_WITH_EMAIL=your-profile@gmail.com

# Optional: copy an existing spreadsheet template instead of creating a blank one.
# The template must be shared with the service account email.
GOOGLE_TEMPLATE_SPREADSHEET_ID=

# Optional: archive JSON downloaded from the web app's Backup tab.
PLANNING_COPILOT_ARCHIVE=
